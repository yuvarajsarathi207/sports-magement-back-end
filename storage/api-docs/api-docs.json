                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/organizer/tournaments": {
            "get": {
                "tags": [
                    "Organizer"
                ],
                "summary": "List all tournaments for organizer",
                "operationId": "d9ec984ceb3d2c8b08d40e49694184de",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by status",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "draft",
                                "open",
                                "active",
                                "expired",
                                "published"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of tournaments"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Organizer"
                ],
                "summary": "Create a new tournament",
                "operationId": "98adc0975c6f70a14626cfafa22cec41",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "sports_category_id",
                                    "team_name",
                                    "location",
                                    "start_date",
                                    "winning_date",
                                    "slot_count",
                                    "rules",
                                    "entry_fee"
                                ],
                                "properties": {
                                    "sports_category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "team_name": {
                                        "type": "string",
                                        "example": "Team Alpha"
                                    },
                                    "location": {
                                        "type": "string",
                                        "example": "Stadium A"
                                    },
                                    "location_details": {
                                        "type": "string",
                                        "example": "Near City Center"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-02-01"
                                    },
                                    "winning_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-02-15"
                                    },
                                    "slot_count": {
                                        "type": "integer",
                                        "example": 16
                                    },
                                    "template": {
                                        "type": "string",
                                        "example": "Template details"
                                    },
                                    "rules": {
                                        "type": "string",
                                        "example": "Tournament rules"
                                    },
                                    "entry_fee": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 100
                                    },
                                    "price_details": {
                                        "type": "string",
                                        "example": "Price breakdown"
                                    },
                                    "ball_type": {
                                        "type": "string",
                                        "example": "Football"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Tournament created successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
